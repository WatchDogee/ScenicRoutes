{
  "version": 1,
  "type": "docker-compose",
  "services": {
    "app": {
      "port": 3000,
      "environment": [
        "APP_ENV=production",
        "APP_DEBUG=true",
        "APP_URL=${APP_URL}",
        "DB_CONNECTION=mysql",
        "DB_HOST=${DB_HOST}",
        "DB_PORT=${DB_PORT}",
        "DB_DATABASE=${DB_DATABASE}",
        "DB_USERNAME=${DB_USERNAME}",
        "DB_PASSWORD=${DB_PASSWORD}"
      ],
      "volumes": [
        {
          "source": ".",
          "target": "/app"
        },
        {
          "source": "app_storage",
          "target": "/app/storage"
        },
        {
          "source": "app_bootstrap_cache",
          "target": "/app/bootstrap/cache"
        }
      ],
      "healthcheck": {
        "test": ["CMD-SHELL", "curl -f http://localhost/health || exit 0"],
        "interval": "10s",
        "timeout": "5s",
        "retries": 3,
        "start_period": "30s"
      }
    }
  },
  "volumes": ["app_storage", "app_bootstrap_cache"],
  "networks": ["app_network"],
  "deploy": {
    "command": [
      "cd /app && mkdir -p /app/storage/logs",
      "cd /app && mkdir -p /app/storage/framework/sessions",
      "cd /app && mkdir -p /app/storage/framework/views",
      "cd /app && mkdir -p /app/storage/framework/cache",
      "cd /app && chmod -R 777 /app/storage",
      "cd /app && chmod -R 777 /app/bootstrap/cache",
      "cd /app && touch /app/storage/logs/laravel.log",
      "cd /app && chmod 666 /app/storage/logs/laravel.log",
      "cd /app && cp .env.coolify .env",
      "cd /app && php artisan key:generate --force",
      "cd /app && php artisan config:clear",
      "cd /app && php artisan cache:clear",
      "cd /app && php artisan view:clear",
      "cd /app && php artisan route:clear",
      "cd /app && php artisan storage:link",
      "cd /app && php artisan migrate --force",
      "cd /app && npm install",
      "cd /app && npm run build",
      "cd /app && chown -R www-data:www-data /app/storage /app/bootstrap/cache"
    ]
  }
}


