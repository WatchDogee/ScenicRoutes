{
  "version": 1,
  "type": "docker-compose",
  "services": {
    "app": {
      "port": 3000,
      "environment": [
        "APP_ENV=production",
        "APP_DEBUG=true",
        "APP_URL=${APP_URL}",
        "DB_CONNECTION=mysql",
        "DB_HOST=${DB_HOST}",
        "DB_PORT=${DB_PORT}",
        "DB_DATABASE=${DB_DATABASE}",
        "DB_USERNAME=${DB_USERNAME}",
        "DB_PASSWORD=${DB_PASSWORD}",
        "CACHE_DRIVER=file",
        "SESSION_DRIVER=cookie",
        "QUEUE_CONNECTION=database",
        "MAIL_MAILER=${MAIL_MAILER}",
        "MAIL_HOST=${MAIL_HOST}",
        "MAIL_PORT=${MAIL_PORT}",
        "MAIL_USERNAME=${MAIL_USERNAME}",
        "MAIL_PASSWORD=${MAIL_PASSWORD}",
        "MAIL_ENCRYPTION=${MAIL_ENCRYPTION}",
        "MAIL_FROM_ADDRESS=${MAIL_FROM_ADDRESS}",
        "LOG_CHANNEL=stack",
        "BROADCAST_DRIVER=log",
        "SANCTUM_STATEFUL_DOMAINS=${SANCTUM_STATEFUL_DOMAINS}",
        "SESSION_DOMAIN=${SESSION_DOMAIN}",
        "PHP_MEMORY_LIMIT=2G",
        "PHP_MAX_EXECUTION_TIME=600",
        "PHP_POST_MAX_SIZE=64M",
        "PHP_UPLOAD_MAX_FILESIZE=64M",
        "WEB_DOCUMENT_ROOT=/app/public",
        "WEB_DOCUMENT_INDEX=index.php",
        "WEB_NGINX_CONF=/app/docker/nginx/custom-nginx.conf",
        "COMPOSER_MEMORY_LIMIT=-1"
      ],
      "volumes": [
        {
          "source": ".",
          "target": "/app"
        },
        {
          "source": "app_storage",
          "target": "/app/storage"
        },
        {
          "source": "app_bootstrap_cache",
          "target": "/app/bootstrap/cache"
        }
      ],
      "healthcheck": {
        "test": ["CMD-SHELL", "curl -f http://localhost/health.php || exit 0"],
        "interval": "30s",
        "timeout": "10s",
        "retries": 5,
        "start_period": "60s"
      }
    }
  },
  "volumes": ["app_storage", "app_bootstrap_cache"],
  "networks": ["app_network"],
  "deploy": {
    "command": [
      "cd /app && mkdir -p /app/storage/logs /app/storage/framework/sessions /app/storage/framework/views /app/storage/framework/cache",
      "cd /app && chmod -R 777 /app/storage /app/bootstrap/cache",
      "cd /app && touch /app/storage/logs/laravel.log && chmod 666 /app/storage/logs/laravel.log",
      "cd /app && cp .env.coolify .env",
      "cd /app && php artisan key:generate --force",
      "cd /app && php artisan config:clear && php artisan cache:clear && php artisan view:clear && php artisan route:clear",
      "cd /app && php artisan storage:link",
      "cd /app && php artisan migrate --force --no-interaction",
      "cd /app && npm ci --no-audit --no-fund",
      "cd /app && npm run build",
      "cd /app && chown -R www-data:www-data /app/storage /app/bootstrap/cache"
    ]
  }
}
