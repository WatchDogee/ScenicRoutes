{
  "version": 1,
  "type": "docker-compose",
  "services": {
    "app": {
      "port": 8090,
      "environment": [
        "APP_ENV=production",
        "APP_DEBUG=false",
        "APP_URL=${APP_URL}",
        "DB_CONNECTION=mysql",
        "DB_HOST=${DB_HOST}",
        "DB_PORT=${DB_PORT}",
        "DB_DATABASE=${DB_DATABASE}",
        "DB_USERNAME=${DB_USERNAME}",
        "DB_PASSWORD=${DB_PASSWORD}",
        "CACHE_DRIVER=file",
        "SESSION_DRIVER=file",
        "QUEUE_CONNECTION=database",
        "MAIL_MAILER=${MAIL_MAILER}",
        "MAIL_HOST=${MAIL_HOST}",
        "MAIL_PORT=${MAIL_PORT}",
        "MAIL_USERNAME=${MAIL_USERNAME}",
        "MAIL_PASSWORD=${MAIL_PASSWORD}",
        "MAIL_ENCRYPTION=${MAIL_ENCRYPTION}",
        "MAIL_FROM_ADDRESS=${MAIL_FROM_ADDRESS}",
        "LOG_CHANNEL=stack",
        "BROADCAST_DRIVER=log",
        "SANCTUM_STATEFUL_DOMAINS=${SANCTUM_STATEFUL_DOMAINS}",
        "SESSION_DOMAIN=${SESSION_DOMAIN}",
        "PHP_MEMORY_LIMIT=2G",
        "PHP_MAX_EXECUTION_TIME=600",
        "PHP_POST_MAX_SIZE=64M",
        "PHP_UPLOAD_MAX_FILESIZE=64M",
        "WEB_DOCUMENT_ROOT=/app/public",
        "WEB_DOCUMENT_INDEX=index.php",
        "COMPOSER_MEMORY_LIMIT=-1"
      ],
      "volumes": [
        {
          "source": ".",
          "target": "/app"
        },
        {
          "source": "app_storage",
          "target": "/app/storage"
        },
        {
          "source": "app_bootstrap_cache",
          "target": "/app/bootstrap/cache"
        }
      ],
      "healthcheck": {
        "test": ["CMD-SHELL", "curl -f http://localhost || exit 0"],
        "interval": "30s",
        "timeout": "10s",
        "retries": 5,
        "start_period": "60s"
      }
    }
  },
  "volumes": ["app_storage", "app_bootstrap_cache"],
  "networks": ["app_network"],
  "deploy": {
    "command": [
      "cd /app && mkdir -p /app/storage/logs",
      "cd /app && mkdir -p /app/storage/framework/sessions",
      "cd /app && mkdir -p /app/storage/framework/views",
      "cd /app && mkdir -p /app/storage/framework/cache",
      "cd /app && chmod -R 775 /app/storage",
      "cd /app && chmod -R 775 /app/bootstrap/cache",
      "cd /app && php artisan key:generate --force",
      "cd /app && php artisan migrate --force",
      "cd /app && php artisan config:cache",
      "cd /app && php artisan route:cache",
      "cd /app && php artisan view:cache",
      "cd /app && php artisan storage:link",
      "cd /app && chown -R application:application /app/storage /app/bootstrap/cache"
    ]
  }
}
